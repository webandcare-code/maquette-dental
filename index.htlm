<!DOCTYPE html>
<html>
<head>
    <title>SmileCare Dental Clinic</title>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
    <div class="logo">SmileCare</div>
    <nav>
        <a href="index.html">Home</a>
        <a href="about.html">About</a>
        <a href="services.html">Services</a>
        <a href="team.html">Team</a>
        <a href="reviews.html">Reviews</a>
        <a href="contact.html">Contact</a>
    </nav>
    <div>
        <button class="lang-btn" onclick="setLanguage('en')">EN</button>
        <button class="lang-btn" onclick="setLanguage('gr')">GR</button>
    </div>
</header>

<section class="hero">
    <h1 data-en="Modern Dental Care for the Whole Family"
        data-gr="Σύγχρονη Οδοντιατρική Φροντίδα για Όλη την Οικογένεια">
        Modern Dental Care for the Whole Family
    </h1>
    <a href="contact.html" class="button"
       data-en="Book an Appointment"
       data-gr="Κλείστε Ραντεβού">
       Book an Appointment
    </a>
</section>

<section class="section">
    <h2 data-en="Why Choose Us?"
        data-gr="Γιατί να μας επιλέξετε;">
        Why Choose Us?
    </h2>
    <div class="card-grid">
        <div class="card">
            <h3>Advanced Technology</h3>
            <p>We use the latest dental equipment.</p>
        </div>
        <div class="card">
            <h3>Experienced Dentists</h3>
            <p>Over 15 years of experience.</p>
        </div>
        <div class="card">
            <h3>Emergency Care</h3>
            <p>Available for urgent treatments.</p>
        </div>
    </div>
</section>

<footer>
    © 2026 SmileCare Dental Clinic
</footer>

<script src="script.js"></script>
</body>
</html>
